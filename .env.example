# GitHub fine-grained PAT with Contents: Read on the scripts repo.
# Used to clone/pull the private scripts repo. Redacted in all TUI output.
GITHUB_TOKEN=

# HTTPS URL of the private scripts repo (overrides scriptsRepo in config.json)
# SCRIPTS_REPO=https://github.com/YOUR_ORG/your-powershell-scripts-repo

# Optional: n8n webhook endpoint (overrides n8nWebhookUrl in config.json)
# N8N_WEBHOOK_URL=

# Optional: enables plain-English -> cron conversion when scheduling (e key)
# OPENROUTER_API_KEY=

# Required to start the MCP server (psscripts --mcp): shared Bearer token the
# n8n MCP Client credential must present. Generate one: openssl rand -hex 32
# MCP_AUTH_TOKEN=
