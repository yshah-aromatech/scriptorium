# GitHub fine-grained PAT with Contents: Read on the scripts repo.
# Used to clone/pull the private scripts repo. Redacted in all TUI output.
GITHUB_TOKEN=

# Optional: n8n webhook endpoint (overrides n8nWebhookUrl in config.json)
# N8N_WEBHOOK_URL=

# Optional: enables plain-English -> cron conversion when scheduling (e key)
# OPENROUTER_API_KEY=
