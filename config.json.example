{
  "scriptsRepo": "https://github.com/YOUR_ORG/your-powershell-scripts-repo",
  "branch": "main",
  "repos": [],
  "dataDir": "~/.scriptorium",
  "n8nWebhookUrl": "",
  "pwshBin": "pwsh",
  "pythonBin": "python3",
  "monitorIntervalMs": 1000,
  "logTailKb": 64,
  "runTimeoutMinutes": 0,
  "maxOutputLines": 5000,
  "openRouterModel": "google/gemini-3.1-flash-lite",
  "syncOnLaunch": false,
  "logRetentionDays": 30,
  "historyMaxLines": 5000,
  "historyDays": 7,
  "webhookTimeoutSec": 15,
  "colorMode": "auto",
  "mcpPort": 8765,
  "mcpBind": "all"
}
